#!/usr/bin/env bash
# Pre-push hook — refuses to push unless smoke.sh passes.
# Installed as a symlink by scripts/install-git-hooks.sh; edits to this file
# propagate to the hook automatically.
#
# Bypass for genuinely one-off cases (not a habit):  git push --no-verify
set -e
exec "$(git rev-parse --show-toplevel)/scripts/smoke.sh"
