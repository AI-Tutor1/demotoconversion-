# Frontend environment variables.
# Copy to .env.local for local dev.
# For Vercel production: set these same three keys in Vercel → Project → Settings → Environment Variables.
#
# NEXT_PUBLIC_* vars are bundled into the browser build — they are NOT secret.
# Only the Supabase anon key (browser-safe, RLS-enforced) and public URLs go here.

# ─── Supabase ───
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# ─── Python AI Backend ───
# URL of the FastAPI backend.
#   Local dev:     http://localhost:8000
#   Vercel prod:   https://demo-to-conversion-backend.onrender.com  (fill in after Render deploy)
NEXT_PUBLIC_AI_BACKEND_URL=http://localhost:8000

# ─── Optional: Analytics (Phase 4) ───
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
