# Backend — local/production environment variables.
# Copy to .env for local dev; set these same keys in Render for production.

# Groq API key — used for BOTH Whisper transcription and the demo_analyst LLM.
# Get one at https://console.groq.com/keys
GROQ_API_KEY=gsk_...your-groq-key

# Supabase — URL + service-role (admin) key. Service role bypasses RLS so
# NEVER expose it to the browser. It only lives server-side (here + Render).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Comma-separated list of origins the frontend is allowed to call from.
# Locally: the Next dev server. In Render: your Vercel production URL.
# Vercel preview URLs (*.vercel.app) are allowed via regex automatically.
FRONTEND_ORIGINS=http://localhost:3000

# NOTE: user-access-token verification uses ES256 + the project's JWKS endpoint
# ({SUPABASE_URL}/auth/v1/.well-known/jwks.json). No JWT signing secret is
# required; the backend fetches the public key automatically.

# ─── Auto-retry of failed sessions (app/scheduler.py) ─────────
# All five are optional — the defaults shown here match the values baked into
# config.py. Override only when you need to tune the scheduler at runtime
# (e.g. set AUTO_RETRY_ENABLED=false during a Groq incident).
#
# AUTO_RETRY_ENABLED=true                    # master kill switch
# AUTO_RETRY_INTERVAL_MINUTES=15             # how often the scheduler wakes
# AUTO_RETRY_MAX_ATTEMPTS=3                  # failed task_queue rows per session
# AUTO_RETRY_RATE_LIMIT_BACKOFF_MINUTES=60   # after an ASPH / 429
# AUTO_RETRY_GENERIC_BACKOFF_MINUTES=5       # after any other transient error
